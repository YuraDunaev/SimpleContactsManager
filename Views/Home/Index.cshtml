@{
    ViewData["Title"] = "Contacts Management";
}

<div class="container mt-4">
    <!-- Header Panel -->
    <div class="header-panel d-flex justify-content-between align-items-center mb-4">
        <h1>
            <i class="bi bi-people-fill me-2"></i>Contacts
        </h1>
        <div class="d-flex gap-2">
            <button type="button" class="btn btn-light text-dark fw-semibold shadow-sm" onclick="toggleFilters()">
                <i class="bi bi-funnel me-1"></i> Filters
            </button>
            <button type="button" class="btn btn-light text-dark fw-semibold shadow-sm" onclick="openCreateModal()">
                <i class="bi bi-plus-lg me-1"></i> Add Contact
            </button>
        </div>
    </div>

    <div class="row">
        <!-- Filter Sidebar -->
        <div class="col-lg-3 mb-4" id="filterSidebar">
            <div class="card-panel">
                <h6 class="fw-semibold mb-3 text-primary">
                    <i class="bi bi-funnel me-1"></i>Search & Filters
                </h6>

                <div class="mb-3">
                    <label class="form-label small">Search</label>
                    <div class="input-group">
                        <input type="text" class="form-control" id="filterSearch"
                               placeholder="Name or phone..."
                               oninput="onFilterChange()" />
                        <button class="btn btn-outline-secondary" type="button" onclick="document.getElementById('filterSearch').value=''; onFilterChange();">
                            <i class="bi bi-x-lg"></i>
                        </button>
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label small">Country Code</label>
                    <select class="form-select" id="filterCountryCode" onchange="onFilterChange()">
                        <option value="">All countries</option>
                        <option value="+1">+1 — USA/Canada</option>
                        <option value="+7">+7 — Russia/Kazakhstan</option>
                        <option value="+44">+44 — United Kingdom</option>
                        <option value="+49">+49 — Germany</option>
                        <option value="+33">+33 — France</option>
                        <option value="+375">+375 — Belarus</option>
                        <option value="+380">+380 — Ukraine</option>
                        <option value="+48">+48 — Poland</option>
                        <option value="+86">+86 — China</option>
                        <option value="+91">+91 — India</option>
                        <option value="+55">+55 — Brazil</option>
                        <option value="+81">+81 — Japan</option>
                        <option value="+82">+82 — South Korea</option>
                        <option value="+61">+61 — Australia</option>
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label small">Job Title</label>
                    <input type="text" class="form-control" id="filterJobTitle"
                           placeholder="e.g. Developer"
                           oninput="onFilterChange()" />
                </div>

                <div class="d-grid">
                    <button class="btn btn-outline-secondary btn-sm" onclick="resetFilters()">
                        <i class="bi bi-arrow-counterclockwise me-1"></i>Reset Filters
                    </button>
                </div>

                <hr class="my-3" />
                <div class="small text-muted" id="filterStats">
                    Showing <strong id="shownCount">0</strong> of <strong id="totalCount">0</strong> contacts
                </div>
            </div>
        </div>

        <!-- Main Content -->
        <div class="col-lg-9" style="max-height: 66vh;overflow: auto;">
            <div class="card-panel">
                <div class="table-responsive">
                    <table class="table align-middle" id="contactsTable">
                        <thead>
                            <tr>
                                <th class="sortable" data-sort="name" onclick="toggleSort('name')">
                                    Name <i class="bi bi-arrow-down-up sort-icon"></i>
                                </th>
                                <th class="sortable" data-sort="country" onclick="toggleSort('country')">
                                    Mobile Phone <i class="bi bi-arrow-down-up sort-icon"></i>
                                </th>
                                <th>Job Title</th>
                                <th>Birth Date</th>
                                <th class="sortable" data-sort="created" onclick="toggleSort('created')">
                                    Created <i class="bi bi-arrow-down-up sort-icon"></i>
                                </th>
                                <th class="text-center" style="width: 150px;">Actions</th>
                            </tr>
                        </thead>
                        <tbody id="contactsTableBody">
                            <!-- Contacts will be loaded here -->
                        </tbody>
                    </table>
                </div>

                <!-- Pagination -->
                <nav class="d-flex justify-content-between align-items-center mt-3 pt-3 border-top" id="paginationNav" style="display: none !important;">
                    <div class="small text-muted" id="paginationInfo">
                        Page <strong id="currentPageLabel">1</strong> of <strong id="totalPagesLabel">1</strong>
                    </div>
                    <ul class="pagination pagination-sm mb-0">
                        <li class="page-item" id="prevPageBtn">
                            <a class="page-link" href="#" onclick="goToPage(currentPage - 1)" aria-label="Previous">
                                <i class="bi bi-chevron-left"></i>
                            </a>
                        </li>
                        <li class="page-item disabled" id="pageNumbersContainer" style="display: inline-flex !important;">
                            <span class="page-link" id="pageNumbers">1</span>
                        </li>
                        <li class="page-item" id="nextPageBtn">
                            <a class="page-link" href="#" onclick="goToPage(currentPage + 1)" aria-label="Next">
                                <i class="bi bi-chevron-right"></i>
                            </a>
                        </li>
                    </ul>
                    <div class="d-flex align-items-center gap-2">
                        <label class="small text-muted mb-0">Show:</label>
                        <select class="form-select form-select-sm" style="width: auto;" id="pageSizeSelect" onchange="onPageSizeChange()">
                            <option value="5" selected>5</option>
                            <option value="10">10</option>
                            <option value="20">20</option>
                            <option value="50">50</option>
                        </select>
                    </div>
                </nav>
            </div>
        </div>
    </div>
</div>

<!-- Add/Edit Contact Modal -->
<div class="modal fade" id="contactModal" tabindex="-1" aria-labelledby="contactModalLabel" data-bs-backdrop="static">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="contactModalLabel">
                    <i class="bi bi-person-plus-fill me-2"></i>Add Contact
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="contactForm" novalidate>
                    <input type="hidden" id="contactId" value="0" />

                    <div class="mb-4">
                        <label for="contactName" class="form-label">
                            <i class="bi bi-person me-1"></i>Name <span class="text-danger">*</span>
                        </label>
                        <input type="text" class="form-control" id="contactName" required
                               minlength="2" maxlength="100"
                               pattern="^[a-zA-Zа-яА-ЯёЁ\s\-']+$"
                               placeholder="Enter full name" />
                        <div class="invalid-feedback" id="nameError"></div>
                    </div>

                    <div class="mb-4">
                        <label for="contactPhone" class="form-label">
                            <i class="bi bi-phone me-1"></i>Mobile Phone <span class="text-danger">*</span>
                        </label>
                        <input type="tel" class="form-control" id="contactPhone" required
                               pattern="^\+?\d{10,15}$"
                               placeholder="+1234567890" />
                        <div class="invalid-feedback" id="phoneError"></div>
                        <div class="form-text small" id="phoneUniqueMsg"></div>
                    </div>

                    <div class="mb-4">
                        <label for="contactJobTitle" class="form-label">
                            <i class="bi bi-briefcase me-1"></i>Job Title
                        </label>
                        <input type="text" class="form-control" id="contactJobTitle" maxlength="100"
                               placeholder="Enter job title" />
                        <div class="invalid-feedback" id="jobTitleError"></div>
                    </div>

                    <div class="mb-3">
                        <label for="contactBirthDate" class="form-label">
                            <i class="bi bi-calendar me-1"></i>Birth Date <span class="text-danger">*</span>
                        </label>
                        <input type="date" class="form-control" id="contactBirthDate" required />
                        <div class="invalid-feedback" id="birthDateError"></div>
                    </div>
                </form>
            </div>
            <div class="modal-footer d-flex justify-content-between">
                <button type="button" class="btn btn-primary px-4" id="saveContactBtn" onclick="saveContact()">
                    <i class="bi bi-check-lg me-1"></i>Save
                </button>
                <button type="button" class="btn btn-secondary px-4" data-bs-dismiss="modal">
                    <i class="bi bi-x-lg me-1"></i>Cancel
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel">
    <div class="modal-dialog modal-sm modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-danger">
                <h5 class="modal-title" id="deleteModalLabel">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>Confirm Delete
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-center py-4">
                <i class="bi bi-trash3 text-danger" style="font-size: 3rem;"></i>
                <p class="mt-3 mb-0">Are you sure you want to delete <strong id="deleteContactName"></strong>?</p>
            </div>
            <div class="modal-footer d-flex justify-content-between">
                <button type="button" class="btn btn-danger px-3" id="confirmDeleteBtn" onclick="deleteContact()">
                    <i class="bi bi-trash me-1"></i>Delete
                </button>
                <button type="button" class="btn btn-secondary px-3" data-bs-dismiss="modal">
                    <i class="bi bi-x-lg me-1"></i>Cancel
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Toast notification -->
<div class="toast-container position-fixed start-50 translate-middle-x" style="top: 20px; z-index: 99999;">
    <div id="toastNotification" class="toast" role="alert" aria-live="assertive" aria-atomic="true">
        <div class="toast-header">
            <i class="bi bi-info-circle-fill me-2"></i>
            <strong class="me-auto" id="toastTitle">Notification</strong>
            <button type="button" class="btn-close" data-bs-dismiss="toast" aria-label="Close"></button>
        </div>
        <div class="toast-body" id="toastMessage"></div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <script src="~/js/site.js" asp-append-version="true"></script>
}